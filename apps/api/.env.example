NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:3005,http://localhost:5173
REQUEST_BODY_LIMIT=1mb
# Use a PostgreSQL user that exists (e.g. postgres). Create DB first: psql -U postgres -c "CREATE DATABASE ifms;"
DATABASE_URL=postgresql://postgres:1618@localhost:5432/ifms
RUN_MIGRATIONS_ON_STARTUP=false
ALLOW_PROD_STARTUP_MIGRATIONS=false
ENABLE_SWAGGER=true
REPORTS_EXPLAIN=false
SWAGGER_BASIC_USER=admin
SWAGGER_BASIC_PASS=change-me-in-production
JWT_ACCESS_SECRET=change-me-in-production-min-32-characters-now
JWT_REFRESH_SECRET=change-me-refresh-in-prod-32-characters
JWT_ACCESS_TTL=900
JWT_REFRESH_DAYS=7
REPORTS_CACHE_ENABLED=true
REPORTS_CACHE_MAX_ENTRIES=500
REPORTS_CACHE_TTL_SECONDS_DEFAULT=60
REPORTS_CACHE_TTL_SECONDS_OVERVIEW=60
REPORTS_CACHE_TTL_SECONDS_DAILY_OPERATIONS=60
REPORTS_CACHE_TTL_SECONDS_STOCK_LOSS=60
REPORTS_CACHE_TTL_SECONDS_PROFITABILITY=60
REPORTS_CACHE_TTL_SECONDS_CREDIT_CASHFLOW=60
REPORTS_CACHE_TTL_SECONDS_STATION_COMPARISON=120
REPORTS_SLOW_QUERY_THRESHOLD_MS=2000
OPS_METRICS_ENABLED=false
GOVERNANCE_ENABLED=false
ALLOW_OVERLAPPING_SHIFTS=false
SHIFT_VARIANCE_REQUIRE_REASON_THRESHOLD=0
SALES_DISCOUNT_REQUIRE_MANAGER_THRESHOLD=10
SALES_ROUNDING_TOLERANCE=0.01
DELIVERY_VARIANCE_REQUIRE_REASON_THRESHOLD=0
EXPORT_STORAGE_DIR=storage/exports
EXPORT_EXPIRES_HOURS=72
EXPORT_OUTBOX_POLL_INTERVAL_SECONDS=10
EXPORT_VERIFY_BASE_URL=https://www.itembagroup.llc/public/report/verify
EXPORT_DEFAULT_RETENTION_DAYS=2555
EXPORT_SIGN_REGULATORY_ONLY=true
EXPORT_STRICT_SIGNING_REQUIRED=false

SIGNING_PROVIDER=file
SIGNING_KEY_ID=
SIGNING_CERT_PEM=
SIGNING_KEY_ENCRYPTED=
SIGNING_KEY_PASSPHRASE=
SIGNING_ORG_DISPLAY=ITEMBA-ENERGIES (IFMS)

TSA_URL=
TSA_PROVIDER=internal-tsa
TSA_TIMEOUT_MS=5000

# Seed / reset-admin credentials (used by npm run db:seed & db:reset-admin)
ADMIN_SEED_EMAIL=admin@ifms.local
ADMIN_SEED_PASSWORD=1618

# Email (SMTP) — required for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# SMS (optional) — HTTP-based SMS provider
SMS_PROVIDER_URL=
SMS_API_KEY=

# AI keys (optional)
GEMINI_API_KEY=
GROQ_API_KEY=

# Database pool tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONN_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
# SSL: false | require | no-verify (must be 'require' or 'no-verify' in production)
DB_SSL=false
